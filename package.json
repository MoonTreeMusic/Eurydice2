{
  "name": "moo-music",
  "version": "0.1.0",
  "description": "Help humans listen to their music on their terms",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"electron .\"",
    "build": "vite build && tsc --noEmit false --outDir dist-electron src/main/main.js",
    "start": "concurrently -k \"vite\" \"electron .\"",
    "test": "vitest run",
    "fix-electron": "node scripts/fix-electron.js",
    "postinstall": "node scripts/fix-electron.js"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.1",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.5"
  },
  "dependencies": {
    "music-metadata": "7.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
